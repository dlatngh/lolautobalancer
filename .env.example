# Copy this file to .env and fill in real values. Do not commit your .env.

# Riot Games API key — required to fetch player ranks and levels.
# Get one at https://developer.riotgames.com/
# NOTE: development keys expire every 24 hours. An always-on deployment
# (e.g. the Discord bot hitting this app) needs a registered production key.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Shared secret that gates POST /api/balance (the bot-facing endpoint).
# The Discord bot must send this exact value in the `X-Bot-Secret` header.
# Fails closed: if this is unset, every /api/balance request is rejected (401).
# Generate one with: openssl rand -hex 32
BOT_SHARED_SECRET=replace-with-a-long-random-string
